5 CLEAR 8192
10 CLS
20 PRINT "BASIC KSS PLAYER"
30 PRINT "UNMODIFIED KSS/KSSX FILE"
40 BLOAD "BASICKSS.BIN"
45 POKE &H7FF6,0
50 DEF USR=&HC000
60 INPUT "KSS FILE";F$
65 INPUT "SONG (0-255)";T:POKE &H7FF7,T AND 255
70 OPEN F$ FOR INPUT AS #1
80 S=LOF(1):N=INT(S/255):M=S-N*255
90 FOR R=1 TO N
100 B$=INPUT$(255,#1)
110 P=VARPTR(B$):IF P<0 THEN P=P+65536
120 Q=PEEK(P+1)+256*PEEK(P+2):POKE &H7FF0,Q-INT(Q/256)*256:POKE &H7FF1,INT(Q/256)
130 X=USR(0)
135 X=FRE("")
140 NEXT R
150 IF M=0 THEN 180
160 B$=INPUT$(M,#1)+STRING$(255-M,0)
170 P=VARPTR(B$):IF P<0 THEN P=P+65536
175 Q=PEEK(P+1)+256*PEEK(P+2):POKE &H7FF0,Q-INT(Q/256)*256:POKE &H7FF1,INT(Q/256):X=USR(0)
176 X=FRE("")
180 CLOSE #1
190 POKE &H7FF3,S-INT(S/256)*256:POKE &H7FF4,INT(S/256)-INT(S/65536)*256:POKE &H7FF5,INT(S/65536)
200 POKE &H7FF6,1:X=USR(0)
