+/* SCPZ is the ZX0-compressed Salamander complete-page container. It stores
+ * the relocated 16K page-1 template once and a compressed payload plus an
+ * absolute page-offset patch set for each logical song page. */
+static int materialize_salamander_compressed_complete_pages(
+    KSS *kss, uint32_t header_size, uint8_t *bank_data, KSSPLAY *kssplay) {
+  const uint8_t *tail;
+  uint8_t *snapshot = NULL;
+  uint32_t tail_offset, tail_size, page_count, template_packed;
+  uint32_t template_offset, page, i;
+
+  if (!kss || !kss->kssx || kss->bank_mode != BANK_16K ||
+      kss->bank_num != 14 || kss->load_adr != 0x0200 ||
+      kss->init_adr != 0x5f97 || kss->play_adr != 0x5fc3)
+    return 1;
+  tail_offset = header_size + kss->load_len;
+  if (tail_offset > kss->size || kss->size - tail_offset < 532 ||
+      memcmp(kss->data + tail_offset, "SCPZ", 4) != 0)
+    return 1;
+  tail = kss->data + tail_offset;
+  tail_size = kss->size - tail_offset;
+  if (tail[4] != 1 || tail[5] != 14 || tail[6] != 14 ||
+      ((uint32_t)tail[8] | ((uint32_t)tail[9] << 8)) != 0x4000 ||
+      ((uint32_t)tail[10] | ((uint32_t)tail[11] << 8)) != 0x4000)
+    return 0;
+  page_count = tail[5];
+  template_packed = (uint32_t)tail[528] | ((uint32_t)tail[529] << 8);
+  template_offset = (uint32_t)tail[530] | ((uint32_t)tail[531] << 8);
+  if (532 + page_count * 10 > tail_size ||
+      template_offset + template_packed > tail_size)
+    return 0;
+
+  if (kssplay) {
+    memset(kssplay->quarth_song_page, 0xff,
+           sizeof(kssplay->quarth_song_page));
+    memset(kssplay->quarth_song_id, 0xff,
+           sizeof(kssplay->quarth_song_id));
+    for (i = 0; i < 256; i++) {
+      kssplay->quarth_song_id[i] = tail[16 + i];
+      kssplay->quarth_song_page[i] = tail[272 + i];
+    }
+    kssplay->quarth_complete_page = 1;
+  }
+
+  if (bank_data) {
+    snapshot = malloc(tail_size);
+    if (!snapshot)
+      return 0;
+    memcpy(snapshot, tail, tail_size);
+    tail = snapshot;
+  }
+
+  for (page = 0; page < page_count; page++) {
+    uint32_t descriptor = 532 + page * 10;
+    uint32_t data_size = (uint32_t)tail[descriptor] |
+                         ((uint32_t)tail[descriptor + 1] << 8);
+    uint32_t patch_count = (uint32_t)tail[descriptor + 2] |
+                           ((uint32_t)tail[descriptor + 3] << 8);
+    uint32_t packed_size = (uint32_t)tail[descriptor + 4] |
+                           ((uint32_t)tail[descriptor + 5] << 8);
+    uint32_t stream_offset = (uint32_t)tail[descriptor + 6] |
+                             ((uint32_t)tail[descriptor + 7] << 8);
+    uint32_t patch_offset = (uint32_t)tail[descriptor + 8] |
+                            ((uint32_t)tail[descriptor + 9] << 8);
+    uint8_t *output;
+    if (data_size > 0x4000 || patch_count > 1024 ||
+        stream_offset + packed_size > tail_size ||
+        patch_offset + patch_count * 4 > tail_size)
+      goto scpz_bad;
+    for (i = 0; i < patch_count; i++) {
+      uint32_t entry = patch_offset + i * 4;
+      uint32_t offset = (uint32_t)tail[entry] |
+                        ((uint32_t)tail[entry + 1] << 8);
+      if (offset + 2 > 0x4000)
+        goto scpz_bad;
+    }
+    if (!bank_data)
+      continue;
+    output = bank_data + page * 0x4000;
+    if (!zx0_decompress_data(tail + template_offset, template_packed,
+                             output, 0x4000) ||
+        !zx0_decompress_data(tail + stream_offset, packed_size,
+                             output, data_size))
+      goto scpz_bad;
+    for (i = 0; i < patch_count; i++) {
+      uint32_t entry = patch_offset + i * 4;
+      uint32_t offset = (uint32_t)tail[entry] |
+                        ((uint32_t)tail[entry + 1] << 8);
+      output[offset] = tail[entry + 2];
+      output[offset + 1] = tail[entry + 3];
+    }
+  }
+  free(snapshot);
+  return 2;
+scpz_bad:
+  free(snapshot);
+  return 0;
+}
