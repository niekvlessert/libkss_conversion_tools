+/* SCPX stores one relocated Salamander page-1 template plus one payload and
+ * descriptor patch set per required song. */
+static int materialize_salamander_complete_pages(KSS *kss,
+                                                  uint32_t header_size,
+                                                  uint8_t *bank_data,
+                                                  KSSPLAY *kssplay) {
+  const uint8_t *tail;
+  uint8_t *snapshot = NULL;
+  uint32_t tail_offset, tail_size, template_size, payload_address;
+  uint32_t page_count, cursor, page, i;
+  uint32_t record_offset[0x80], data_size[0x80], patch_count[0x80];
+
+  if (!kss || !kss->kssx || kss->bank_mode != BANK_16K ||
+      kss->bank_num != 14 || kss->load_adr != 0x0200 ||
+      kss->init_adr != 0x5f97 || kss->play_adr != 0x5fc3)
+    return 1;
+  tail_offset = header_size + kss->load_len;
+  if (tail_offset > kss->size || kss->size - tail_offset < 528 ||
+      memcmp(kss->data + tail_offset, "SCPX", 4) != 0)
+    return 1;
+  tail = kss->data + tail_offset;
+  tail_size = kss->size - tail_offset;
+  if (tail[4] != 1 || tail[5] != 14 || tail[6] != 14)
+    return 0;
+  page_count = tail[5];
+  template_size = (uint32_t)tail[8] | ((uint32_t)tail[9] << 8);
+  payload_address = (uint32_t)tail[10] | ((uint32_t)tail[11] << 8);
+  if (template_size != 0x4000 || payload_address != 0x4000 ||
+      528 + template_size > tail_size)
+    return 0;
+  if (kssplay) {
+    memset(kssplay->quarth_song_page, 0xff,
+           sizeof(kssplay->quarth_song_page));
+    memset(kssplay->quarth_song_id, 0xff,
+           sizeof(kssplay->quarth_song_id));
+    for (i = 0; i < 256; i++) {
+      kssplay->quarth_song_id[i] = tail[16 + i];
+      kssplay->quarth_song_page[i] = tail[272 + i];
+    }
+    kssplay->quarth_complete_page = 1;
+  }
+  cursor = 528 + template_size;
+  for (page = 0; page < page_count; page++) {
+    uint32_t patches;
+    if (cursor + 4 > tail_size)
+      return 0;
+    record_offset[page] = cursor;
+    data_size[page] = (uint32_t)tail[cursor] |
+                      ((uint32_t)tail[cursor + 1] << 8);
+    patches = (uint32_t)tail[cursor + 2] |
+              ((uint32_t)tail[cursor + 3] << 8);
+    patch_count[page] = patches;
+    cursor += 4;
+    if (data_size[page] > 0x4000 || patches > 1024 ||
+        cursor + patches * 4 + data_size[page] > tail_size)
+      return 0;
+    for (i = 0; i < patches; i++) {
+      uint32_t offset = (uint32_t)tail[cursor + i * 4] |
+                        ((uint32_t)tail[cursor + i * 4 + 1] << 8);
+      if (offset + 2 > 0x4000)
+        return 0;
+    }
+    cursor += patches * 4 + data_size[page];
+  }
+  if (!bank_data)
+    return 2;
+  snapshot = malloc(tail_size);
+  if (!snapshot)
+    return 0;
+  memcpy(snapshot, tail, tail_size);
+  tail = snapshot;
+  for (page = 0; page < page_count; page++) {
+    uint8_t *output = bank_data + page * 0x4000;
+    uint32_t patch_cursor = record_offset[page] + 4;
+    memcpy(output, tail + 528, 0x4000);
+    for (i = 0; i < patch_count[page]; i++) {
+      uint32_t offset = (uint32_t)tail[patch_cursor] |
+                        ((uint32_t)tail[patch_cursor + 1] << 8);
+      output[offset] = tail[patch_cursor + 2];
+      output[offset + 1] = tail[patch_cursor + 3];
+      patch_cursor += 4;
+    }
+    memcpy(output + payload_address - 0x4000, tail + patch_cursor,
+           data_size[page]);
+  }
+  free(snapshot);
+  return 2;
+}
