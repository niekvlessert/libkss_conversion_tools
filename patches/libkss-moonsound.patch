+static uint32_t compact_kssx_loader_end(KSSPLAY *kssplay) {
+  if (!kssplay || !kssplay->kss || !kssplay->kss->kssx ||
+      kssplay->kss->load_adr != 0x0200 ||
+      kssplay->kss->init_adr != 0x0200)
+    return 0;
+  if (kssplay->kss->play_adr == 0x52df &&
+      kssplay->kss->bank_mode == BANK_16K && kssplay->kss->bank_num == 2)
+    return 0x0300; /* Quarth: bootstrap and decoder only. */
+  if (!kssplay->kss->ram_mode || kssplay->kss->bank_num != 0)
+    return 0;
+  if (kssplay->kss->play_adr == 0x5f80)
+    return 0x5f00; /* F-1 Spirit: engine starts at 5F00H. */
+  if (kssplay->kss->play_adr == 0x5fe0)
+    return 0x5f50; /* Nemesis 3: injected bank switcher ends before 5FC0H. */
+  return 0;
+}
