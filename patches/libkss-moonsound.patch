+/* N3ZX is the private tail used by the compact Nemesis 3 KSSX builder. The
+ * KSS header describes three normal 16K banks, while this tail stores their
+ * ZX0 streams. Expand them here, before VM_init_bank() and before the Z80
+ * engine starts, so bank selection remains instantaneous during playback. */
+static int materialize_nemesis3_banks(KSS *kss, uint32_t header_size,
+                                      uint8_t *bank_data) {
+  const uint8_t *tail;
+  uint32_t tail_offset, length[3], compressed_size, i;
+  uint8_t *compressed;
+  const uint8_t *stream;
+
+  if (!kss || !kss->kssx || kss->bank_mode != BANK_16K ||
+      kss->bank_num != 3 || kss->load_adr != 0x0200 ||
+      kss->init_adr != 0x0200 || kss->play_adr != 0x5fe0)
+    return 1;
+
+  tail_offset = header_size + kss->load_len;
+  if (tail_offset > kss->size || kss->size - tail_offset < 10 ||
+      memcmp(kss->data + tail_offset, "N3ZX", 4) != 0)
+    return 1;
+
+  tail = kss->data + tail_offset;
+  for (i = 0; i < 3; i++)
+    length[i] = (uint32_t)tail[4 + i * 2] |
+                ((uint32_t)tail[5 + i * 2] << 8);
+  compressed_size = length[0] + length[1] + length[2];
+  if (compressed_size < length[0] || compressed_size < length[1] ||
+      compressed_size < length[2] ||
+      compressed_size > kss->size - tail_offset - 10)
+    return 0;
+
+  /* A NULL destination is the validation pass performed before realloc(). */
+  if (!bank_data)
+    return 2;
+
+  /* Decoding bank 0 overwrites the tail, so preserve all streams first. */
+  compressed = malloc(compressed_size);
+  if (!compressed)
+    return 0;
+  memcpy(compressed, tail + 10, compressed_size);
+
+  stream = compressed;
+  if (!zx0_decompress_data(stream, length[0], bank_data, 0x4000)) {
+    free(compressed);
+    return 0;
+  }
+
+  /* All three Nemesis 3 banks share the lower 8K. Store that common half in
+   * each physical bank, then decode only the two distinct upper halves. */
+  memcpy(bank_data + 0x4000, bank_data, 0x2000);
+  memcpy(bank_data + 0x8000, bank_data, 0x2000);
+  stream += length[0];
+  if (!zx0_decompress_data(stream, length[1], bank_data + 0x6000, 0x2000)) {
+    free(compressed);
+    return 0;
+  }
+  stream += length[1];
+  if (!zx0_decompress_data(stream, length[2], bank_data + 0xa000, 0x2000)) {
+    free(compressed);
+    return 0;
+  }
+
+  free(compressed);
+  return 2;
+}
+
+/* QRTX is the private tail used by the compact Quarth KSSX builder. Quarth's
+ * two 16K banks share a 0x12D1-byte prefix, but it is not an 8K boundary. The
+ * tail stores that prefix once, followed by the used portions of bank 0 and
+ * bank 1. Rebuild the ordinary two-bank image before VM_init_bank(). */
+static int materialize_quarth_banks(KSS *kss, uint32_t header_size,
+                                     uint8_t *bank_data) {
+  const uint8_t *tail;
+  uint32_t tail_offset, length[3], compressed_size, i;
+  uint8_t *compressed;
+  const uint8_t *stream;
+
+  if (!kss || !kss->kssx || kss->bank_mode != BANK_16K ||
+      kss->bank_num != 2 || kss->bank_offset != 0 ||
+      kss->load_adr != 0x0200 || kss->init_adr != 0x0200 ||
+      kss->play_adr != 0x52df)
+    return 1;
+
+  tail_offset = header_size + kss->load_len;
+  if (tail_offset > kss->size || kss->size - tail_offset < 10 ||
+      memcmp(kss->data + tail_offset, "QRTX", 4) != 0)
+    return 1;
+
+  tail = kss->data + tail_offset;
+  for (i = 0; i < 3; i++)
+    length[i] = (uint32_t)tail[4 + i * 2] |
+                ((uint32_t)tail[5 + i * 2] << 8);
+  compressed_size = length[0] + length[1] + length[2];
+  if (compressed_size < length[0] || compressed_size < length[1] ||
+      compressed_size < length[2] ||
+      compressed_size > kss->size - tail_offset - 10)
+    return 0;
+
+  if (!bank_data)
+    return 2;
+
+  /* Decoding into bank_data overwrites the QRTX tail in the expanded KSS
+   * allocation, so preserve every compressed stream first. */
+  compressed = malloc(compressed_size);
+  if (!compressed)
+    return 0;
+  memcpy(compressed, tail + 10, compressed_size);
+
+  memset(bank_data, 0, 2 * 0x4000);
+  stream = compressed;
+  if (!zx0_decompress_data(stream, length[0], bank_data, 0x12d1)) {
+    free(compressed);
+    return 0;
+  }
+  memcpy(bank_data + 0x4000, bank_data, 0x12d1);
+  stream += length[0];
+  if (!zx0_decompress_data(stream, length[1], bank_data + 0x12d1,
+                           0x2d29)) {
+    free(compressed);
+    return 0;
+  }
+  stream += length[1];
+  if (!zx0_decompress_data(stream, length[2], bank_data + 0x4000 + 0x12d1,
+                           0x2d29)) {
+    free(compressed);
+    return 0;
+  }
+
+  free(compressed);
+  return 2;
+}
+
+/* KCPX/KCPZ are generic page-1 containers for integrated Konami drivers.
+ * They store one common 16K template plus sparse per-song overlays. */
+static int apply_konami_page_overlay(uint8_t *output, const uint8_t *overlay,
+                                     uint32_t overlay_size) {
+  uint32_t cursor = 0;
+  while (cursor < overlay_size) {
+    uint32_t offset, length;
+    if (overlay_size - cursor < 4)
+      return 0;
+    offset = (uint32_t)overlay[cursor] |
+             ((uint32_t)overlay[cursor + 1] << 8);
+    length = (uint32_t)overlay[cursor + 2] |
+             ((uint32_t)overlay[cursor + 3] << 8);
+    cursor += 4;
+    if (offset + length > 0x4000 || cursor + length > overlay_size)
+      return 0;
+    memcpy(output + offset, overlay + cursor, length);
+    cursor += length;
+  }
+  return 1;
+}
+
+static int materialize_konami_complete_pages(KSS *kss,
+                                              uint32_t header_size,
+                                              uint8_t *bank_data,
+                                              KSSPLAY *kssplay) {
+  const uint8_t *tail;
+  uint8_t *snapshot = NULL;
+  uint32_t tail_offset, tail_size, page_count, cursor, page, i;
+  uint32_t record_offset[0x80], record_size[0x80];
+
+  if (!kss || !kss->kssx || kss->bank_mode != BANK_16K ||
+      kss->bank_num < 1 || kss->bank_num > 0x7f ||
+      kss->load_adr != 0x0200)
+    return 1;
+  tail_offset = header_size + kss->load_len;
+  if (tail_offset > kss->size || kss->size - tail_offset < 528 ||
+      memcmp(kss->data + tail_offset, "KCPX", 4) != 0)
+    return 1;
+  tail = kss->data + tail_offset;
+  tail_size = kss->size - tail_offset;
+  page_count = tail[5];
+  if (tail[4] != 1 || page_count != kss->bank_num || tail[6] == 0 ||
+      ((uint32_t)tail[8] | ((uint32_t)tail[9] << 8)) != 0x4000 ||
+      528 + 0x4000 > tail_size)
+    return 0;
+  if (kssplay) {
+    memset(kssplay->quarth_song_page, 0xff,
+           sizeof(kssplay->quarth_song_page));
+    memset(kssplay->quarth_song_id, 0xff,
+           sizeof(kssplay->quarth_song_id));
+    for (i = 0; i < 256; i++) {
+      kssplay->quarth_song_id[i] = tail[16 + i];
+      kssplay->quarth_song_page[i] = tail[272 + i];
+    }
+    kssplay->quarth_complete_page = 1;
+  }
+  cursor = 528 + 0x4000;
+  for (page = 0; page < page_count; page++) {
+    if (cursor + 2 > tail_size)
+      return 0;
+    record_size[page] = (uint32_t)tail[cursor] |
+                        ((uint32_t)tail[cursor + 1] << 8);
+    cursor += 2;
+    record_offset[page] = cursor;
+    if (cursor + record_size[page] > tail_size)
+      return 0;
+    cursor += record_size[page];
+  }
+  if (!bank_data)
+    return 2;
+  snapshot = malloc(tail_size);
+  if (!snapshot)
+    return 0;
+  memcpy(snapshot, tail, tail_size);
+  tail = snapshot;
+  for (page = 0; page < page_count; page++) {
+    uint8_t *output = bank_data + page * 0x4000;
+    memcpy(output, tail + 528, 0x4000);
+    if (!apply_konami_page_overlay(output, tail + record_offset[page],
+                                   record_size[page])) {
+      free(snapshot);
+      return 0;
+    }
+  }
+  free(snapshot);
+  return 2;
+}
+
+static int materialize_konami_compressed_pages(KSS *kss,
+                                                uint32_t header_size,
+                                                uint8_t *bank_data,
+                                                KSSPLAY *kssplay) {
+  const uint8_t *tail;
+  uint8_t *snapshot = NULL, *overlay = NULL;
+  uint32_t tail_offset, tail_size, page_count, template_size;
+  uint32_t template_offset, page, i;
+
+  if (!kss || !kss->kssx || kss->bank_mode != BANK_16K ||
+      kss->bank_num < 1 || kss->bank_num > 0x7f ||
+      kss->load_adr != 0x0200)
+    return 1;
+  tail_offset = header_size + kss->load_len;
+  if (tail_offset > kss->size || kss->size - tail_offset < 532 ||
+      memcmp(kss->data + tail_offset, "KCPZ", 4) != 0)
+    return 1;
+  tail = kss->data + tail_offset;
+  tail_size = kss->size - tail_offset;
+  page_count = tail[5];
+  template_size = (uint32_t)tail[528] | ((uint32_t)tail[529] << 8);
+  template_offset = (uint32_t)tail[530] | ((uint32_t)tail[531] << 8);
+  if (tail[4] != 1 || page_count != kss->bank_num || tail[6] == 0 ||
+      ((uint32_t)tail[8] | ((uint32_t)tail[9] << 8)) != 0x4000 ||
+      532 + page_count * 6 > tail_size ||
+      template_offset + template_size > tail_size)
+    return 0;
+  if (kssplay) {
+    memset(kssplay->quarth_song_page, 0xff,
+           sizeof(kssplay->quarth_song_page));
+    memset(kssplay->quarth_song_id, 0xff,
+           sizeof(kssplay->quarth_song_id));
+    for (i = 0; i < 256; i++) {
+      kssplay->quarth_song_id[i] = tail[16 + i];
+      kssplay->quarth_song_page[i] = tail[272 + i];
+    }
+    kssplay->quarth_complete_page = 1;
+  }
+  if (!bank_data)
+    return 2;
+  snapshot = malloc(tail_size);
+  overlay = malloc(0x10000);
+  if (!snapshot || !overlay) {
+    free(snapshot); free(overlay); return 0;
+  }
+  memcpy(snapshot, tail, tail_size);
+  tail = snapshot;
+  for (page = 0; page < page_count; page++) {
+    uint32_t descriptor = 532 + page * 6;
+    uint32_t raw_size = (uint32_t)tail[descriptor] |
+                        ((uint32_t)tail[descriptor + 1] << 8);
+    uint32_t packed_size = (uint32_t)tail[descriptor + 2] |
+                           ((uint32_t)tail[descriptor + 3] << 8);
+    uint32_t stream_offset = (uint32_t)tail[descriptor + 4] |
+                             ((uint32_t)tail[descriptor + 5] << 8);
+    uint8_t *output = bank_data + page * 0x4000;
+    if (raw_size > 0xffff || stream_offset + packed_size > tail_size ||
+        !zx0_decompress_data(tail + template_offset, template_size,
+                             output, 0x4000) ||
+        !zx0_decompress_data(tail + stream_offset, packed_size,
+                             overlay, raw_size) ||
+        !apply_konami_page_overlay(output, overlay, raw_size)) {
+      free(snapshot); free(overlay); return 0;
+    }
+  }
+  free(snapshot);
+  free(overlay);
+  return 2;
+}
+
+static int materialize_compressed_banks(KSS *kss, uint32_t header_size,
+                                         uint8_t *bank_data,
+                                         KSSPLAY *kssplay) {
+  int materialized = materialize_konami_compressed_pages(
+      kss, header_size, bank_data, kssplay);
+  if (materialized != 1)
+    return materialized;
+  materialized = materialize_konami_complete_pages(
+      kss, header_size, bank_data, kssplay);
+  if (materialized != 1)
+    return materialized;
+  materialized = materialize_salamander_compressed_complete_pages(
+      kss, header_size, bank_data, kssplay);
+  if (materialized != 1)
+    return materialized;
+  materialized = materialize_salamander_complete_pages(
+      kss, header_size, bank_data, kssplay);
+  if (materialized != 1)
+    return materialized;
+  materialized = materialize_quarth_compressed_complete_pages(
+      kss, header_size, bank_data, kssplay);
+  if (materialized != 1)
+    return materialized;
+  materialized = materialize_quarth_complete_pages(
+      kss, header_size, bank_data, kssplay);
+  if (materialized != 1)
+    return materialized;
+  materialized = materialize_nemesis3_banks(kss, header_size, bank_data);
+  if (materialized != 1)
+    return materialized;
+  return materialize_quarth_banks(kss, header_size, bank_data);
+}
