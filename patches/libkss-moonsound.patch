+static int is_quarth_map_kss(const KSSPLAY *kssplay) {
+  const KSS *kss = kssplay ? kssplay->kss : NULL;
+  if (kssplay && kssplay->quarth_complete_page)
+    return 1;
+  if (!kss || kss->bank_mode != BANK_16K || kss->bank_num != 2 ||
+      kss->play_adr != 0x52df)
+    return 0;
+  return kss->load_adr == 0x4000 ||
+         (kss->kssx && kss->load_adr == 0x0200 &&
+          kss->init_adr == 0x0200);
+}
