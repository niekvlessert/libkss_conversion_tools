+/* DMV1 MBWave uses the MWM base-frequency byte to drive its timer. A normal
+ * KSS play callback is scheduled at the video refresh rate, which is not
+ * correct for all of these songs. */
+static int is_mbwave_kss(KSSPLAY *kssplay) {
+  const uint8_t *song;
+  uint32_t offset;
+
+  if (!kssplay || !kssplay->kss || !kssplay->main_data ||
+      kssplay->kss->load_adr != 0x4000 || kssplay->kss->init_adr != 0x7f30 ||
+      kssplay->kss->play_adr != 0x45e5)
+    return 0;
+  offset = 0x8000u - kssplay->kss->load_adr;
+  if (offset + 6u > kssplay->kss->load_len)
+    return 0;
+  song = kssplay->main_data + offset;
+  return memcmp(song, "MBMS\x10\x08", 6) == 0;
+}
+
+static double mbwave_frequency_from_base(uint8_t base_frequency) {
+  if (base_frequency == 0)
+    return 60.0;
+  if (base_frequency == 1)
+    return 50.0;
+  return 1.0 / ((double)base_frequency * 0.0000808) + 0.5;
+}
+
+static uint8_t mbwave_header_base_frequency(KSSPLAY *kssplay) {
+  const uint8_t *song;
+  uint32_t offset;
+
+  if (!is_mbwave_kss(kssplay))
+    return 0xff;
+  offset = 0x8000u - kssplay->kss->load_adr;
+  if (offset + 6u + 0x1cu > kssplay->kss->load_len)
+    return 0xff;
+  song = kssplay->main_data + offset;
+  return song[6u + 0x1bu];
+}
+
+static double mbwave_vsync_frequency(KSSPLAY *kssplay) {
+  uint8_t base_frequency;
+
+  base_frequency = mbwave_header_base_frequency(kssplay);
+  if (base_frequency == 0xff)
+    return 0.0;
+  return mbwave_frequency_from_base(base_frequency);
+}
