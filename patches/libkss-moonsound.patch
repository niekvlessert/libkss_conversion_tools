+static void mbwave_sync_frequency(KSSPLAY *kssplay) {
+  uint8_t base_frequency;
+  double frequency;
+
+  if (!kssplay->mbwave_timing)
+    return;
+
+  base_frequency = (uint8_t)MMAP_read_memory(kssplay->vm->mmap, 0x4e69);
+  /* MBPLAY fills the work area during its first PLAY call. Until then, a
+   * zero byte is just the cleared work area; keep the header timing. */
+  if (!kssplay->mbwave_runtime_ready && base_frequency == 0 &&
+      kssplay->mbwave_base_frequency != 0)
+    return;
+  kssplay->mbwave_runtime_ready = 1;
+  if (base_frequency == kssplay->mbwave_base_frequency)
+    return;
+
+  kssplay->mbwave_base_frequency = base_frequency;
+  frequency = mbwave_frequency_from_base(base_frequency);
+  if (fabs(frequency - kssplay->vsync_freq) < 0.000001)
+    return;
+
+  kssplay->vsync_freq = frequency;
+  VM_set_clock(kssplay->vm, getclk(kssplay), frequency);
+}
