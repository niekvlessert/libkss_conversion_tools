+/* QCPZ is the ZX0-compressed form of the complete-page Quarth container.
+ * Stream offsets are relative to the QCPZ magic. Each page is reconstructed
+ * as a normal writable 16K bank before the VM starts. */
+static int materialize_quarth_compressed_complete_pages(
+    KSS *kss, uint32_t header_size, uint8_t *bank_data, KSSPLAY *kssplay) {
+  const uint8_t *tail;
+  uint32_t tail_offset, tail_size, engine_size, common_size;
+  uint32_t page_data_address, page_count, engine_packed, engine_offset;
+  uint32_t common_packed, common_offset, page, i;
+  uint8_t *tail_snapshot = NULL;
+
+  if (!kss || !kss->kssx || kss->bank_mode != BANK_16K ||
+      kss->bank_num < 1 || kss->load_adr != 0x0200 ||
+      kss->init_adr != 0x52bb || kss->play_adr != 0x52df)
+    return 1;
+  tail_offset = header_size + kss->load_len;
+  if (tail_offset > kss->size || kss->size - tail_offset < 586 ||
+      memcmp(kss->data + tail_offset, "QCPZ", 4) != 0)
+    return 1;
+  tail = kss->data + tail_offset;
+  tail_size = kss->size - tail_offset;
+  if (tail[4] != 1 || tail[5] != kss->bank_num || tail[6] != 19 ||
+      tail[5] > 0x7f)
+    return 0;
+  page_count = tail[5];
+  engine_size = (uint32_t)tail[8] | ((uint32_t)tail[9] << 8);
+  common_size = (uint32_t)tail[10] | ((uint32_t)tail[11] << 8);
+  page_data_address = (uint32_t)tail[12] | ((uint32_t)tail[13] << 8);
+  engine_packed = (uint32_t)tail[528] | ((uint32_t)tail[529] << 8);
+  engine_offset = (uint32_t)tail[530] | ((uint32_t)tail[531] << 8);
+  common_packed = (uint32_t)tail[532] | ((uint32_t)tail[533] << 8);
+  common_offset = (uint32_t)tail[534] | ((uint32_t)tail[535] << 8);
+  if (page_data_address < 0x4000 ||
+      engine_size + common_size != page_data_address - 0x4000 ||
+      engine_size + common_size > 0x4000 ||
+      engine_offset + engine_packed > tail_size ||
+      common_offset + common_packed > tail_size ||
+      536 + page_count * 10 > tail_size)
+    return 0;
+
+  if (kssplay) {
+    memset(kssplay->quarth_song_page, 0xff,
+           sizeof(kssplay->quarth_song_page));
+    memset(kssplay->quarth_song_id, 0xff,
+           sizeof(kssplay->quarth_song_id));
+    for (i = 0; i < 256; i++) {
+      kssplay->quarth_song_id[i] = tail[16 + i];
+      kssplay->quarth_song_page[i] = tail[272 + i];
+    }
+    kssplay->quarth_complete_page = 1;
+  }
+
+  /* The expanded bank area begins at the QCPZ tail. Preserve all compressed
+   * streams before page 0 overwrites the source from which it is decoding. */
+  if (bank_data) {
+    tail_snapshot = malloc(tail_size);
+    if (!tail_snapshot)
+      return 0;
+    memcpy(tail_snapshot, tail, tail_size);
+    tail = tail_snapshot;
+  }
+
+  for (page = 0; page < page_count; page++) {
+    uint32_t descriptor = 536 + page * 10;
+    uint32_t data_size = (uint32_t)tail[descriptor] |
+                         ((uint32_t)tail[descriptor + 1] << 8);
+    uint32_t patch_count = (uint32_t)tail[descriptor + 2] |
+                           ((uint32_t)tail[descriptor + 3] << 8);
+    uint32_t packed_size = (uint32_t)tail[descriptor + 4] |
+                           ((uint32_t)tail[descriptor + 5] << 8);
+    uint32_t stream_offset = (uint32_t)tail[descriptor + 6] |
+                             ((uint32_t)tail[descriptor + 7] << 8);
+    uint32_t patch_offset = (uint32_t)tail[descriptor + 8] |
+                            ((uint32_t)tail[descriptor + 9] << 8);
+    uint8_t *output;
+    if (data_size > 0x4000 || patch_count > 1024 ||
+        page_data_address - 0x4000 + data_size > 0x4000 ||
+        stream_offset + packed_size > tail_size ||
+        patch_offset + patch_count * 4 > tail_size)
+      goto qcpz_bad;
+    for (i = 0; i < patch_count; i++) {
+      uint32_t offset = (uint32_t)tail[patch_offset + i * 4] |
+                        ((uint32_t)tail[patch_offset + i * 4 + 1] << 8);
+      if (offset + 2 > common_size)
+        goto qcpz_bad;
+    }
+    if (!bank_data)
+      continue;
+    output = bank_data + page * 0x4000;
+    memset(output, 0, 0x4000);
+    if (!zx0_decompress_data(tail + engine_offset, engine_packed,
+                             output, engine_size) ||
+        !zx0_decompress_data(tail + common_offset, common_packed,
+                             output + engine_size, common_size) ||
+        !zx0_decompress_data(tail + stream_offset, packed_size,
+                             output + page_data_address - 0x4000, data_size))
+      goto qcpz_bad;
+    for (i = 0; i < patch_count; i++) {
+      uint32_t entry = patch_offset + i * 4;
+      uint32_t offset = (uint32_t)tail[entry] |
+                        ((uint32_t)tail[entry + 1] << 8);
+      output[engine_size + offset] = tail[entry + 2];
+      output[engine_size + offset + 1] = tail[entry + 3];
+    }
+  }
+  free(tail_snapshot);
+  return 2;
+qcpz_bad:
+  free(tail_snapshot);
+  return 0;
+}
+
+/* QCPX is the uncompressed complete-page Quarth container.  It stores one
+ * engine/common template followed by per-page stream payloads and patches.
+ * The materializer expands those records into ordinary 16K banks so the VM
+ * and existing KSS tooling still operate on normal mapper pages. */
+static int materialize_quarth_complete_pages(KSS *kss, uint32_t header_size,
+                                             uint8_t *bank_data,
+                                             KSSPLAY *kssplay) {
+  const uint8_t *tail;
+  uint32_t tail_offset, engine_size, common_size, page_data_address;
+  uint32_t page_count, cursor, page, i;
+  uint32_t record_offset[0x80], record_data_size[0x80];
+  uint32_t record_patch_count[0x80];
+  uint8_t *tail_snapshot = NULL;
+
+  if (!kss || !kss->kssx || kss->bank_mode != BANK_16K ||
+      kss->bank_num < 1 || kss->load_adr != 0x0200 ||
+      kss->init_adr != 0x52bb || kss->play_adr != 0x52df)
+    return 1;
+
+  tail_offset = header_size + kss->load_len;
+  if (tail_offset > kss->size || kss->size - tail_offset < 528 ||
+      memcmp(kss->data + tail_offset, "QCPX", 4) != 0)
+    return 1;
+
+  tail = kss->data + tail_offset;
+  if (tail[4] != 1 || tail[5] != kss->bank_num || tail[6] != 19)
+    return 0;
+  page_count = tail[5];
+  engine_size = (uint32_t)tail[8] | ((uint32_t)tail[9] << 8);
+  common_size = (uint32_t)tail[10] | ((uint32_t)tail[11] << 8);
+  page_data_address = (uint32_t)tail[12] | ((uint32_t)tail[13] << 8);
+  if (page_data_address < 0x4000 ||
+      engine_size + common_size != page_data_address - 0x4000 ||
+      engine_size + common_size > 0x4000 || page_count > 0x7f)
+    return 0;
+
+  if (kssplay) {
+    memset(kssplay->quarth_song_page, 0xff,
+           sizeof(kssplay->quarth_song_page));
+    memset(kssplay->quarth_song_id, 0xff,
+           sizeof(kssplay->quarth_song_id));
+    for (i = 0; i < 256; i++) {
+      kssplay->quarth_song_id[i] = tail[16 + i];
+      kssplay->quarth_song_page[i] = tail[16 + 256 + i];
+    }
+    kssplay->quarth_complete_page = 1;
+  }
+
+  cursor = 16 + 512;
+  if (cursor + engine_size + common_size > kss->size - tail_offset)
+    return 0;
+  cursor += engine_size + common_size;
+
+  for (page = 0; page < page_count; page++) {
+    uint32_t data_size, patch_count;
+
+    if (cursor + 4 > kss->size - tail_offset)
+      return 0;
+    record_offset[page] = cursor;
+    data_size = (uint32_t)tail[cursor] | ((uint32_t)tail[cursor + 1] << 8);
+    patch_count = (uint32_t)tail[cursor + 2] |
+                  ((uint32_t)tail[cursor + 3] << 8);
+    record_data_size[page] = data_size;
+    record_patch_count[page] = patch_count;
+    cursor += 4;
+    if (patch_count > 1024 || data_size > 0x4000 ||
+        cursor + patch_count * 4 + data_size > kss->size - tail_offset)
+      return 0;
+    if (engine_size + common_size + data_size > 0x4000)
+      return 0;
+    for (i = 0; i < patch_count; i++) {
+      uint32_t patch_offset = (uint32_t)tail[cursor + i * 4] |
+                              ((uint32_t)tail[cursor + i * 4 + 1] << 8);
+      if (patch_offset + 2 > common_size)
+        return 0;
+    }
+    cursor += patch_count * 4;
+    cursor += data_size;
+  }
+
+  if (!bank_data)
+    return 2;
+
+  /* bank_data starts directly after the load image and therefore overlaps
+   * the QCPX tail in the expanded KSS allocation. Preserve the source before
+   * writing page 0, otherwise the first page erases its own engine template.
+   */
+  tail_snapshot = malloc(kss->size - tail_offset);
+  if (!tail_snapshot)
+    return 0;
+  memcpy(tail_snapshot, tail, kss->size - tail_offset);
+  tail = tail_snapshot;
+
+  for (page = 0; page < page_count; page++) {
+    uint32_t record = record_offset[page];
+    uint32_t patch_cursor = record + 4;
+    uint8_t *output = bank_data + page * 0x4000;
+    memset(output, 0, 0x4000);
+    memcpy(output, tail + 16 + 512, engine_size);
+    memcpy(output + engine_size, tail + 16 + 512 + engine_size,
+           common_size);
+    for (i = 0; i < record_patch_count[page]; i++) {
+      uint32_t patch_offset = (uint32_t)tail[patch_cursor] |
+                              ((uint32_t)tail[patch_cursor + 1] << 8);
+      uint32_t patch_value = (uint32_t)tail[patch_cursor + 2] |
+                             ((uint32_t)tail[patch_cursor + 3] << 8);
+      output[engine_size + patch_offset] = (uint8_t)patch_value;
+      output[engine_size + patch_offset + 1] = (uint8_t)(patch_value >> 8);
+      patch_cursor += 4;
+    }
+    memcpy(output + page_data_address - 0x4000,
+           tail + patch_cursor, record_data_size[page]);
+  }
+
+  free(tail_snapshot);
+  return 2;
+}
+
+static double mbwave_vsync_frequency(KSSPLAY *kssplay) {
+  uint8_t base_frequency;
+
+  base_frequency = mbwave_header_base_frequency(kssplay);
+  if (base_frequency == 0xff)
+    return 0.0;
+  return mbwave_frequency_from_base(base_frequency);
+}
